<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.StudentAttendanceController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>
            <HBox id="HBox" alignment="CENTER_LEFT" spacing="5.0">
                <Label text="考勤查询" style="-fx-font-size: 18px; -fx-font-weight: bold;">
                    <font>
                        <Font size="18"/>
                    </font>
                </Label>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="开始日期:"/>
                <DatePicker fx:id="startDatePicker" prefWidth="150"/>
                <Label text="结束日期:"/>
                <DatePicker fx:id="endDatePicker" prefWidth="150"/>
                <Button text="刷新" onAction="#onRefreshButtonClick"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="dataTableView">
            <columns>
                <TableColumn fx:id="dateColumn" prefWidth="120.0" text="日期"/>
                <TableColumn fx:id="courseNameColumn" prefWidth="200.0" text="课程名称"/>
                <TableColumn fx:id="statusColumn" prefWidth="100.0" text="考勤状态"/>
                <TableColumn fx:id="remarkColumn" prefWidth="200.0" text="备注"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <FlowPane alignment="CENTER" prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <HBox spacing="20" alignment="CENTER">
                <Label text="出勤总数："/>
                <Label fx:id="presentCountLabel" text="--" style="-fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                <Label text="异常总数："/>
                <Label fx:id="abnormalCountLabel" text="--" style="-fx-font-weight: bold; -fx-text-fill: #F44336;"/>
            </HBox>
        </FlowPane>
    </bottom>
</BorderPane>
