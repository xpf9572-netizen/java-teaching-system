<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teach.javafx.controller.AchievementAddDialogController"
      prefWidth="500" prefHeight="450">
    <padding><Insets bottom="15" left="20" right="20" top="15"/></padding>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
        </rowConstraints>

        <Label text="成就类型:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="typeComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="成果名称:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="级别:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="levelComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="获奖日期:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="awardDateField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="描述:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextArea fx:id="descriptionArea" GridPane.columnIndex="1" GridPane.rowIndex="4" prefHeight="80"/>

        <Label text="证书URL:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="certificateUrlField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="保存" onAction="#onOkButtonClick" prefWidth="80"/>
        <Button text="取消" onAction="#onCancelButtonClick" prefWidth="80"/>
    </HBox>
</VBox>
