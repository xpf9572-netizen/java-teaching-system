<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.teach.javafx.controller.ClassPanelController"
      prefHeight="600.0" prefWidth="900.0"
      stylesheets="@css/styles.css">
    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>

    <children>
        <VBox VBox.vgrow="ALWAYS">
            <children>
                <HBox spacing="10">
                    <children>
                        <Label text="班级编号:"/>
                        <TextField fx:id="queryClassNumField" prefWidth="120"/>
                        <Label text="班级名称:"/>
                        <TextField fx:id="queryClassNameField" prefWidth="120"/>
                        <Button text="查询" onAction="#onQueryButtonClick"/>
                        <Button text="新建" onAction="#onAddButtonClick"/>
                        <Button text="删除" onAction="#onDeleteButtonClick"/>
                    </children>
                </HBox>

                <TableView fx:id="dataTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="classNumColumn" text="班级编号" prefWidth="100"/>
                        <TableColumn fx:id="classNameColumn" text="班级名称" prefWidth="120"/>
                        <TableColumn fx:id="departmentColumn" text="院系" prefWidth="100"/>
                        <TableColumn fx:id="majorColumn" text="专业" prefWidth="100"/>
                        <TableColumn fx:id="counselorColumn" text="辅导员" prefWidth="80"/>
                        <TableColumn fx:id="phoneColumn" text="联系电话" prefWidth="100"/>
                        <TableColumn fx:id="studentCountColumn" text="学生人数" prefWidth="80"/>
                    </columns>
                </TableView>
            </children>
        </VBox>

        <VBox styleClass="bordered-container" spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>
            <children>
                <Label text="班级信息编辑" styleClass="section-title"/>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="100"/>
                        <ColumnConstraints minWidth="150" prefWidth="150"/>
                        <ColumnConstraints minWidth="100" prefWidth="100"/>
                        <ColumnConstraints minWidth="150" prefWidth="150"/>
                    </columnConstraints>

                    <children>
                        <Label text="班级编号:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="classNumField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="班级名称:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <TextField fx:id="classNameField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="院系:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="departmentField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="专业:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="majorField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label text="辅导员:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="counselorField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="联系电话:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <TextField fx:id="phoneField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                        <Label text="学生人数:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="studentCountField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="年级:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                        <TextField fx:id="gradeField" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                        <Label text="状态:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <ComboBox fx:id="statusComboBox" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </children>
                </GridPane>

                <HBox spacing="10" alignment="CENTER">
                    <children>
                        <Button text="保存" onAction="#onSaveButtonClick"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
