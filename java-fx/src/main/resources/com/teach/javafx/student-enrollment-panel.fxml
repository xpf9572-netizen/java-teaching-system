<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.StudentEnrollmentController">

    <top>
        <HBox id="HBox" alignment="CENTER_LEFT" spacing="5.0">
            <padding>
                <Insets bottom="3.0" left="3.0" right="3.0" top="3.0"/>
            </padding>
            <Label text="选课管理" style="-fx-font-size: 18px; -fx-font-weight: bold;">
                <font>
                    <Font size="18"/>
                </font>
            </Label>
            <Pane HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </padding>

            <!-- Available Courses Section -->
            <VBox spacing="5">
                <Label text="可选课程" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TableView fx:id="availableCourseTableView" prefHeight="200.0">
                    <columns>
                        <TableColumn fx:id="courseNumColumn" prefWidth="100.0" text="课程编号"/>
                        <TableColumn fx:id="courseNameColumn" prefWidth="200.0" text="课程名称"/>
                        <TableColumn fx:id="creditColumn" prefWidth="80.0" text="学分"/>
                        <TableColumn fx:id="teacherNameColumn" prefWidth="120.0" text="授课教师"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="选课" onAction="#onEnrollButtonClick"/>
                </HBox>
            </VBox>

            <!-- My Enrollments Section -->
            <VBox spacing="5">
                <Label text="我的选课" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TableView fx:id="myEnrollmentTableView" prefHeight="200.0">
                    <columns>
                        <TableColumn fx:id="enrollCourseNameColumn" prefWidth="200.0" text="课程名称"/>
                        <TableColumn fx:id="semesterColumn" prefWidth="120.0" text="学期"/>
                        <TableColumn fx:id="enrollCreditColumn" prefWidth="80.0" text="学分"/>
                        <TableColumn fx:id="gradeColumn" prefWidth="80.0" text="成绩"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="退选" onAction="#onDropButtonClick"/>
                    <Button text="刷新" onAction="#onRefreshButtonClick"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <FlowPane alignment="CENTER" prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        </FlowPane>
    </bottom>
</BorderPane>
