<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.TeacherScoreController">

    <top>
        <VBox spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="10" left="10" right="10" bottom="5"/>
                </padding>
                <Label text="选择课程：" style="-fx-font-size: 14px;"/>
                <ComboBox fx:id="courseComboBox" onAction="#onCourseSelected" prefWidth="300"/>
            </HBox>
            <HBox id="HBox" alignment="CENTER_LEFT" spacing="5.0">
                <padding>
                    <Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/>
                </padding>
                <Label text="课程名：" style="-fx-font-size: 14px;"/>
                <Label fx:id="courseNameLabel" text="--" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label text="平均成绩：" style="-fx-font-size: 14px;"/>
                <Label fx:id="avgScoreLabel" text="--" style="-fx-font-size: 14px; -fx-text-fill: #2196F3;"/>
                <Label text="学生数：" style="-fx-font-size: 14px;"/>
                <Label fx:id="totalStudentsLabel" text="--" style="-fx-font-size: 14px; -fx-text-fill: #4CAF50;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="dataTableView" editable="true">
            <columns>
                <TableColumn fx:id="studentNumColumn" prefWidth="100.0" text="学号" editable="false"/>
                <TableColumn fx:id="studentNameColumn" prefWidth="100.0" text="姓名" editable="false"/>
                <TableColumn fx:id="classNameColumn" prefWidth="120.0" text="班级" editable="false"/>
                <TableColumn fx:id="markColumn" prefWidth="100.0" text="成绩" editable="true"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <FlowPane alignment="CENTER" prefHeight="50.0" BorderPane.alignment="CENTER">
            <Button text="保存成绩" onAction="#onSaveButtonClick" style="-fx-pref-width: 100; -fx-font-size: 14px;"/>
            <Button text="刷新" onAction="#onRefreshButtonClick" style="-fx-pref-width: 80; -fx-font-size: 14px;">
                <FlowPane.margin>
                    <Insets left="20"/>
                </FlowPane.margin>
            </Button>
        </FlowPane>
    </bottom>
</BorderPane>
