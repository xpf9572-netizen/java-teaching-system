<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      prefHeight="600.0" prefWidth="900.0" stylesheets="@css/styles.css">
    <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
    <children>
        <HBox spacing="10">
            <Label text="工号:"/><TextField fx:id="queryTeacherNumField" prefWidth="100"/>
            <Label text="姓名:"/><TextField fx:id="queryNameField" prefWidth="100"/>
            <Button text="查询" onAction="#onQueryButtonClick"/>
            <Button text="新建" onAction="#onAddButtonClick"/>
            <Button text="删除" onAction="#onDeleteButtonClick"/>
        </HBox>
        <TableView fx:id="dataTableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="teacherNumColumn" text="工号" prefWidth="100"/>
                <TableColumn fx:id="nameColumn" text="姓名" prefWidth="80"/>
                <TableColumn fx:id="genderColumn" text="性别" prefWidth="60"/>
                <TableColumn fx:id="titleColumn" text="职称" prefWidth="100"/>
                <TableColumn fx:id="departmentColumn" text="院系" prefWidth="120"/>
                <TableColumn fx:id="phoneColumn" text="电话" prefWidth="120"/>
                <TableColumn fx:id="emailColumn" text="邮箱" prefWidth="150"/>
            </columns>
        </TableView>
        <VBox styleClass="bordered-container" spacing="10">
            <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
            <Label text="教师信息编辑" styleClass="section-title"/>
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="80"/><ColumnConstraints minWidth="150"/>
                    <ColumnConstraints minWidth="80"/><ColumnConstraints minWidth="150"/>
                </columnConstraints>
                <Label text="工号:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="teacherNumField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="姓名:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="nameField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                <Label text="性别:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="genderComboBox" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="职称:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="titleField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                <Label text="院系:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="departmentField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="电话:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                <TextField fx:id="phoneField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                <Label text="邮箱:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="状态:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                <ComboBox fx:id="statusComboBox" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                <Label text="简介:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextArea fx:id="introduceArea" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="4" prefHeight="60"/>
            </GridPane>
            <HBox spacing="10" alignment="CENTER">
                <Button text="保存" onAction="#onSaveButtonClick"/>
            </HBox>
        </VBox>
    </children>
</VBox>
